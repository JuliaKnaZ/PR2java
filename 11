import java.util.*;
import java.util.stream.Collectors;

public class StreamDemo {
    public static void main(String[] args) {
        List<Integer> numbers = Arrays.asList(1, -2, 3, -4, 5);
        
        System.out.println("Исходный список: " + numbers);
        
        System.out.println("A. Отфильтровать только положительные числа:");
        List<Integer> positiveNumbers = numbers.stream()
                .filter(n -> n > 0)
                .collect(Collectors.toList());
        System.out.println("   Положительные числа: " + positiveNumbers);
        
        System.out.println("B. Возвести их в квадрат:");
        List<Integer> squaredNumbers = positiveNumbers.stream()
                .map(n -> n * n)
                .collect(Collectors.toList());
        System.out.println("   Квадраты чисел: " + squaredNumbers);
        
        System.out.println("C. Собрать результат в новый список:");
        List<Integer> result = squaredNumbers;
        System.out.println("   Результат: " + result);
        
        System.out.println("\nИтоговый результирующий список: " + result);
    }
}
